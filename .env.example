# Copia este archivo a ".env" y rellena tus propios valores.

# Puerto en el que escuchará el servidor
PORT=3000

# Cadena secreta larga y aleatoria, usada para firmar las sesiones (JWT).
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_algo_largo_y_aleatorio

# Carpeta donde se guardarán los archivos .jar de los mods subidos
STORAGE_DIR=./storage

# Ruta del archivo de base de datos SQLite
DB_PATH=./data.sqlite
